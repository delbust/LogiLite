[Desktop Entry]
Type=Application
Version=1.0
Name=@APP_NAME@
Comment=Logitech mouse remapper
Exec=@EXEC@
TryExec=@TRY_EXEC@
Path=@WORKDIR@
Icon=@ICON@
Terminal=false
StartupNotify=false
Categories=Settings;Utility;
Keywords=mouse;logitech;buttons;remap;
StartupWMClass=LogiLite
X-LogiLite-Generated=true
X-LogiLite-SourcePath=@SOURCE_PATH@
@AUTOSTART_LINES@
